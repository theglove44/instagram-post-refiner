[Unit]
Description=Instagram Post Logger — Nightly cron (snapshot + backfill + metrics)
After=network-online.target instagram-logger.service
Wants=network-online.target

[Service]
Type=oneshot
EnvironmentFile=/home/christof21/instagram-post-refiner/.env.local
ExecStart=/usr/bin/curl -sf -H "x-cron-secret: ${CRON_SECRET}" http://localhost:3000/api/cron/nightly
TimeoutStartSec=60

[Install]
WantedBy=multi-user.target
